{
    "name": "pagbank/pagbank-for-woocommerce",
    "version": "2.0.0",
    "autoload": {
        "psr-4": {
            "PagBank_WooCommerce\\": "src/core/"
        }
    },
    "authors": [
        {
            "name": "Elias Júnior",
            "email": "elias@cyclelabs.dev"
        }
    ],
    "scripts": {
        "ci": [
            "./vendor/bin/phpcs",
            "./vendor/bin/phpcbf"
        ],
        "unit": "./vendor/bin/phpunit --coverage-html build/coverage-report"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.13.5",
        "phpunit/phpunit": "^9.6.31",
        "wp-coding-standards/wpcs": "^3.3.0",
        "woocommerce/woocommerce-sniffs": "^1.0.1",
        "slevomat/coding-standard": "^8.22",
        "phpstan/phpstan": "^2.1",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "php-stubs/woocommerce-stubs": "^10.4"
    },
    "require": {
        "php": ">=7.4 <=8.3",
        "jakeasmith/http_build_url": "^1.0.1",
        "giggsey/libphonenumber-for-php": "^8.13.55",
        "nesbot/carbon": "^2.73.0",
        "wilkques/pkce-php": "^2.0.0"
    },
    "config": {
        "platform": {
            "php": "7.4"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
