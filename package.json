{
	"name": "pagbank-for-woocommerce",
	"version": "2.0.0",
	"author": "Elias Júnior <me@eliasjr.dev>",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@10.17.1",
	"scripts": {
		"setup": "./scripts/initial-setup.sh",
		"composer": "./scripts/composer.sh",
		"dev": "npx tsx scripts/dev-ui.ts",
		"prebuild": "pnpm composer install --no-dev --optimize-autoloader",
		"build": "tsc && npx tsx scripts/build-ui.ts",
		"postbuild": "pnpm composer install",
		"preexport": "pnpm composer install --no-dev --optimize-autoloader",
		"export": "tsc && npx tsx scripts/build-ui.ts && npx tsx scripts/export.ts",
		"postexport": "pnpm composer install",
		"lint": "concurrently \"pnpm lint:core\" \"pnpm lint:ui\"",
		"lint:core": "./scripts/phpcs.sh",
		"lint:fix:core": "./scripts/phpcbf.sh",
		"lint:ui": "biome check src scripts",
		"lint:fix:ui": "biome check --write src scripts",
		"analyse": "./scripts/phpstan.sh",
		"test": "./scripts/phpunit.sh",
		"todos": "leasot 'src/**/*.{php,ts,js}'",
		"make:pot": "./scripts/make-pot.sh",
		"generate-md": "wp-readme-to-md --screenshot-url=https://raw.githubusercontent.com/pagseguro/pagbank-for-woocommerce/main/wordpress_org_assets/{screenshot}.png",
		"wp": "docker compose run --rm wordpress-cli wp"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@commitlint/cli": "^20.2.0",
		"@commitlint/config-conventional": "^20.2.0",
		"@types/escape-html": "^1.0.4",
		"@types/jquery": "^3.5.33",
		"@types/jquery.blockui": "^0.0.33",
		"@types/node": "^24.10.2",
		"@types/react": "^18.3.27",
		"@types/react-dom": "^18.3.7",
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"jszip": "^3.10.1",
		"leasot": "^14.4.0",
		"sass": "^1.95.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.2.7",
		"woocommerce-monorepo": "github:woocommerce/woocommerce",
		"wp-readme-to-markdown": "^1.0.1"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"@tanstack/react-query": "^5.90.12",
		"@woocommerce/components": "^13.1.0",
		"@wordpress/api-fetch": "^7.36.0",
		"@wordpress/components": "^30.9.0",
		"@wordpress/data": "^10.36.0",
		"@wordpress/element": "^6.36.0",
		"@wordpress/hooks": "^4.36.0",
		"@wordpress/html-entities": "^4.36.0",
		"@wordpress/i18n": "^6.9.0",
		"@wordpress/notices": "^5.36.0",
		"autonumeric": "^4.10.9",
		"axios": "^1.13.2",
		"card-validator": "^10.0.3",
		"date-fns": "^4.1.0",
		"escape-html": "^1.0.3",
		"jquery": "^3.7.1",
		"jsbarcode": "^3.12.1",
		"libphonenumber-js": "^1.12.31",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-hook-form": "^7.68.0",
		"zod": "^4.1.13"
	}
}
